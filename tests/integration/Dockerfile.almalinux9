FROM almalinux:9
RUN dnf install -y epel-release \
    && dnf install -y sudo git bash bats ShellCheck ca-certificates \
    && dnf clean all \
    && if ! command -v shellcheck >/dev/null 2>&1; then \
         ln -s "$(command -v ShellCheck)" /usr/local/bin/shellcheck; \
       fi

# Create non-root user with passwordless sudo
RUN useradd -m -s /bin/bash tester \
    && echo "tester ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER tester
WORKDIR /home/tester

COPY --chown=tester:tester . /home/tester/install-xen-orchestra/

WORKDIR /home/tester/install-xen-orchestra

CMD ["bats", "tests/integration/test_install_smoke.bats"]
